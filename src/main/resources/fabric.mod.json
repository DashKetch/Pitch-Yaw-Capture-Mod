{
  "schemaVersion": 1,
  "id": "pycap",
  "version": "${version}",
  "name": "Pitch Yaw Capture Mod",
  "description": "A mod that captures the player's pitch/yaw and stores them for further use.",
  "authors": ["Dash_Ketch"],
  "contact": {"https://discord.gg/gEjJwKk8gs": "Discord Server"},
  "license": "All-Rights-Reserved",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dashketch.mods.pycap.client.PycapClient"
    ],
    "main": [
      "dashketch.mods.pycap.Pycap"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
